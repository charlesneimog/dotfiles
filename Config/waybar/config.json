{
  "font": "JetBrainsMono Nerd Font",
  "reload_style_on_change": true,
  "width": 1920,
  "spacing": 1,
  "modules-left": ["wlr/taskbar"],
  "modules-center": ["hyprland/workspaces"],
  "modules-right": [
    // "custom/weather",
    "network",
    "pulseaudio",
    "group/hardware",
    "clock",
    "group/quicklinks-right"
  ],

  "wlr/taskbar": {
    "format": "{icon}",
    "icon-size": "15",
    "on-click": "activate",
    "on-click-right": "close",
    "tooltip-format": "Go to {title}",
    "ignore-list": ["kitty", "kitty-scratchpad"]
  },

  // Hyprland
  "hyprland/workspaces": {
    "format": "{icon}",
    "format-icons": {
      "1": "¾░ûƒ",
      "2": "¯×ò",
      "3": "´ü╝",
      "4": "´Çü",
      "5": "´Ç¡",
      "urgent": "´ü¬"
    },
    "persistent-workspaces": {
      "1": [],
      "2": [],
      "3": [],
      "4": [],
      "5": []
    }
  },
  "hyprland/window": {
    "format": "",
    "icon": true,
    "icon-size": 15,
    "max-length": 30,
    "separate-outputs": true,
    "rewrite": {
      "(.*) - Brave": "$1"
    }
  },

  // Quicklinks
  "group/quicklinks-left": {
    "orientation": "horizontal",
    "modules": ["image", "custom/terminal", "custom/browser", "custom/explorer"]
  },
  "custom/explorer": {
    "format": "´ôö ",
    "tooltip": true,
    "tooltip-format": "´ôö Open Dolphin!",
    "on-click": "dolphin"
  },

  "group/quicklinks-right": {
    "orientation": "horizontal",
    "modules": ["power-profiles-daemon", "idle_inhibitor", "custom/power-menu"]
  },
  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": "´ü« ",
      "deactivated": "´ü░ "
    }
  },
  "custom/power-menu": {
    "format": "´Çæ ",
    "tooltip": true,
    "tooltip-format": "´Çæ Open Wlogout!",
    "on-click": "~/.config/hypr/scripts/power-menu.sh"
  },
  "custom/wallpaper": {
    "format": "´Ç¥ ",
    "tooltip": true,
    "tooltip-format": "´Ç¥ Change Wallpaper!",
    "on-click": "~/.config/rofi/menus/swww.sh"
  },

  "group/settings": {
    "orientation": "horizontal",
    "modules": []
  },
  "temperature": {
    "critical-threshold": 80,
    "format": "{temperatureC}┬░C {icon}",
    "format-icons": ["´Ø½", "´ïë", "´Ø®"]
  },

  "pulseaudio": {
    "format": "{volume}% {icon}",
    "format-bluetooth": "{volume}% {icon}´èö {format_source}",
    "format-bluetooth-muted": "´Ü® {icon}´èö {format_source}",
    "format-muted": "¯¼ñ ¾░Øƒ ´æª {format_source}",
    "format-source": "{volume}% ´ä░",
    "format-source-muted": "´ä▒",
    "format-icons": {
      "default": ["´Çª", "´Çº ", "´Ç¿ "]
    },
    "max-volume": 150,
    "on-click": "pavucontrol"
  },

  "power-profiles-daemon": {
    "format": "{icon}",
    "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
    "tooltip": true,
    "format-icons": {
      "default": "¾▒Éï",
      "performance": "¾▒Éï",
      "balanced": "¾░ùæ",
      "power-saver": "¯ê£"
    }
  },

  // Network setup
  "network": {
    "format": "{ifname}",
    "format-wifi": "{essid} ´ç½ ",
    "format-ethernet": "{bandwidthDownBytes} ¯¢ä ",
    "format-disconnected": "",
    "tooltip-format": "{ifname} via {gwaddr} ¾░èù",
    "tooltip-format-wifi": "{essid} ´ç½",
    "tooltip-format-ethernet": "{ifname} ¯¢ä ",
    "tooltip-format-disconnected": "Disconnected",
    "max-length": 50,
    "interval": 2
  },

  "group/hardware": {
    "orientation": "horizontal",
    "modules": ["cpu", "memory"]
  },
  "cpu": {
    "format": " {usage}% ´ïø ",
    "tooltip": false
  },
  "memory": {
    "format": " {}% ¯ëª "
  },
  "clock": {
    "format": "¾▒æé {:%R %a}",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
    "format-alt": "¾░¿│ {:%d %b %Y}"
  },
  "custom/weather": {
    "format": "{}",
    "interval": 300,
    "return-type": "json",
    "exec": "curl -s 'https://wttr.in/Sao_Paulo?format=1' |jq --unbuffered --compact-output -M -R '{text:.}'",
    "exec-if": "ping wttr.in -c1"
  }
}
