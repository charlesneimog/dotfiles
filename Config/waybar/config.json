{
  "font": "JetBrainsMono Nerd Font",
  "reload_style_on_change": true,
  "width": 1920,
  "spacing": 1,
  "modules-left": ["wlr/taskbar"],
  "modules-center": ["hyprland/workspaces"],
  "modules-right": [
    // "custom/weather",
    "network",
    "pulseaudio",
    "group/hardware",
    "clock",
    "group/quicklinks-right"
  ],

  "wlr/taskbar": {
    "format": "{icon}",
    "icon-size": "15",
    "on-click": "activate",
    "on-click-right": "close",
    "tooltip-format": "Go to {title}",
    "ignore-list": ["kitty", "kitty-scratchpad"]
  },

  // Hyprland
  "hyprland/workspaces": {
    "format": "{icon}",
    "format-icons": {
      "1": "¾░¢¤",
      "2": "Ņ×Ģ",
      "3": "’ü╝",
      "4": "’Ćü",
      "5": "’ĆŁ",
      "urgent": "’ü¬"
    },
    "persistent-workspaces": {
      "1": [],
      "2": [],
      "3": [],
      "4": [],
      "5": []
    }
  },
  "hyprland/window": {
    "format": "",
    "icon": true,
    "icon-size": 15,
    "max-length": 30,
    "separate-outputs": true,
    "rewrite": {
      "(.*) - Brave": "$1"
    }
  },

  // Quicklinks
  "group/quicklinks-left": {
    "orientation": "horizontal",
    "modules": ["image", "custom/terminal", "custom/browser", "custom/explorer"]
  },
  "custom/explorer": {
    "format": "’ōö ",
    "tooltip": true,
    "tooltip-format": "’ōö Open Dolphin!",
    "on-click": "dolphin"
  },

  "group/quicklinks-right": {
    "orientation": "horizontal",
    "modules": ["power-profiles-daemon", "idle_inhibitor", "custom/power-menu"]
  },
  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": "’ü« ",
      "deactivated": "’ü░ "
    }
  },
  "custom/power-menu": {
    "format": "’Ćæ ",
    "tooltip": true,
    "tooltip-format": "’Ćæ Open Wlogout!",
    "on-click": "~/.config/hypr/scripts/power-menu.sh"
  },
  "custom/wallpaper": {
    "format": "’ĆŠ ",
    "tooltip": true,
    "tooltip-format": "’ĆŠ Change Wallpaper!",
    "on-click": "~/.config/rofi/menus/swww.sh"
  },

  "group/settings": {
    "orientation": "horizontal",
    "modules": []
  },
  "temperature": {
    "critical-threshold": 80,
    "format": "{temperatureC}┬░C {icon}",
    "format-icons": ["’Ø½", "’ŗē", "’Ø®"]
  },

  "pulseaudio": {
    "format": "{volume}% {icon}",
    "format-bluetooth": "{volume}% {icon}’Ŗö {format_source}",
    "format-bluetooth-muted": "’Ü® {icon}’Ŗö {format_source}",
    "format-muted": "Ņ¼ż ¾░Ø¤ ’æ” {format_source}",
    "format-source": "{volume}% ’ä░",
    "format-source-muted": "’ä▒",
    "format-icons": {
      "default": ["’Ć”", "’Ć¦ ", "’Ć© "]
    },
    "max-volume": 150,
    "on-click": "pavucontrol"
  },

  "power-profiles-daemon": {
    "format": "{icon}",
    "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
    "tooltip": true,
    "format-icons": {
      "default": "¾▒Éŗ",
      "performance": "¾▒Éŗ",
      "balanced": "¾░Śæ",
      "power-saver": "Ņł£"
    }
  },

  // Network setup
  "network": {
    "format": "{ifname}",
    "format-wifi": "{essid} ’ć½ ",
    "format-ethernet": "{bandwidthDownBytes} ŅĮä ",
    "format-disconnected": "",
    "tooltip-format": "{ifname} via {gwaddr} ¾░ŖŚ",
    "tooltip-format-wifi": "{essid} ’ć½",
    "tooltip-format-ethernet": "{ifname} ŅĮä ",
    "tooltip-format-disconnected": "Disconnected",
    "max-length": 50,
    "interval": 2
  },

  "group/hardware": {
    "orientation": "horizontal",
    "modules": ["cpu", "memory"]
  },
  "cpu": {
    "format": " {usage}% ’ŗø ",
    "tooltip": false
  },
  "memory": {
    "format": " {}% Ņē” "
  },
  "clock": {
    "format": "¾▒æé {:%R %a}",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
    "format-alt": "¾░©│ {:%d %b %Y}"
  }
}
