{
  "font": "JetBrainsMono Nerd Font",
  "reload_style_on_change": true,
  "width": 1920,
  "spacing": 1,
  "modules-left": ["group/quicklinks-right", "wlr/taskbar", "tray"],
  "modules-center": ["hyprland/workspaces"],
  "modules-right": [
    "custom/weather",
    "network",
    "pulseaudio",
    "group/hardware",
    "clock",
    "custom/notification"
  ],

  "wlr/taskbar": {
    "format": "{icon}",
    "icon-size": "15",
    "on-click": "activate",
    "on-click-right": "close",
    "tooltip-format": "Go to {title}",
    "ignore-list": ["kitty", "kitty-scratchpad"]
  },

  "hyprland/workspaces": {
    "format": "{icon}",
    "format-icons": {
      "1": "≤░Ψθ",
      "2": "ΌηΧ",
      "3": "ΎΒ╝",
      "4": "ΎΑΒ",
      "5": "Όυο",
      "6": "ΎΘΒ",

      "urgent": "ΎΒς"
    },
    "persistent-workspaces": {
      "1": [],
      "2": [],
      "3": [],
      "4": [],
      "5": [],
      "6": []
    }
  },

  "tray": {
    "icon-size": 18,
    "spacing": 15,
    "show-passive-items": true
  },

  "hyprland/window": {
    "format": "",
    "icon": true,
    "icon-size": 18,
    "max-length": 30,
    "separate-outputs": true,
    "rewrite": {
      "(.*) - Brave": "$1"
    }
  },

  // Quicklinks
  "group/quicklinks-left": {
    "orientation": "horizontal",
    "modules": ["image", "custom/terminal", "custom/browser", "custom/explorer"]
  },

  "group/quicklinks-right": {
    "orientation": "horizontal",
    "modules": ["custom/power-menu", "idle_inhibitor", "power-profiles-daemon"]
  },
  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": "ΎΒχ ",
      "deactivated": "ΎΒ░ "
    }
  },
  "custom/power-menu": {
    "format": "ΎΑΣ ",
    "tooltip": true,
    "tooltip-format": "ΎΑΣ Open Wlogout!",
    "on-click": "~/.config/hypr/scripts/power-menu.sh"
  },

  "group/settings": {
    "orientation": "horizontal",
    "modules": []
  },
  "temperature": {
    "critical-threshold": 80,
    "format": "{temperatureC}┬░C {icon}",
    "format-icons": ["Ύζτ", "ΎΜΚ", "Ύζσ"]
  },

  "pulseaudio": {
    "format": "{volume}% {icon}",
    "format-bluetooth": "{volume}% {icon}ΎΛΦ {format_source}",
    "format-bluetooth-muted": "Ύγσ {icon}ΎΛΦ {format_source}",
    "format-muted": "Όυν ≤░ζθ ΎΣο {format_source}",
    "format-source": "{volume}% ΎΕ░",
    "format-source-muted": "ΎΕ▒",
    "format-icons": {
      "default": ["ΎΑο", "ΎΑπ ", "ΎΑρ "]
    },
    "max-volume": 150,
    "on-click": "pavucontrol"
  },

  "power-profiles-daemon": {
    "format": "{icon}",
    "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
    "tooltip": true,
    "format-icons": {
      "default": "≤▒ΡΜ",
      "performance": "≤▒ΡΜ",
      "balanced": "≤░ΩΣ",
      "power-saver": "ΌΙε"
    }
  },

  // Network setup
  "network": {
    "format": "{ifname}",
    "format-wifi": "{essid} ΎΘτ ",
    "format-ethernet": "{bandwidthDownBytes} Ό╜Ε ",
    "format-disconnected": "",
    "tooltip-format": "{ifname} via {gwaddr} ≤░ΛΩ",
    "tooltip-format-wifi": "{essid} ΎΘτ",
    "tooltip-format-ethernet": "{ifname} Ό╜Ε ",
    "tooltip-format-disconnected": "Disconnected",
    "max-length": 50,
    "interval": 2
  },

  "custom/notification": {
    "tooltip": false,
    "format-icons": {
      "notification": "ΎΓλ<span foreground='red'><sup>ΎΣΕ</sup></span>",
      "none": "ΎΓλ",
      "dnd-notification": "ΎΘ╖<span foreground='red'><sup>ΎΣΕ</sup></span>",
      "dnd-none": "ΎΘ╖",
      "inhibited-notification": "ΎΓλ<span foreground='red'><sup>ΎΣΕ</sup></span>",
      "inhibited-none": "ΎΓλ",
      "dnd-inhibited-notification": "ΎΘ╖<span foreground='red'><sup>ΎΣΕ</sup></span>",
      "dnd-inhibited-none": "ΎΘ╖"
    },
    "format": "{icon} ",
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
  },

  "battery": {
    "states": {
      "good": 95,
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-charging": "ΎΘο  {capacity}%",
    "format-icons": ["≤░ΓΟ", "≤░Β║", "≤░Β╗", "≤░Β╝", "≤░Β╜", "≤░Β╛", "≤░Β┐", "≤░ΓΑ", "≤░ΓΒ", "≤░ΓΓ", "≤░Β╣"],
    "signal": 12,
    "interval": 5
  },

  "group/hardware": {
    "orientation": "horizontal",
    "modules": ["battery", "cpu", "memory"]
  },

  "cpu": {
    "format": " {usage}% ΎΜδ ",
    "tooltip": false
  },

  "memory": {
    "format": " {}% ΌΚο "
  },
  "clock": {
    "format": "≤▒ΣΓ {:%R %a %d %b}",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
    "format-alt": "≤░ρ│ {:%d %b}"
  },
  "custom/weather": {
    "format": "{}",
    "interval": 300,
    "return-type": "json",
    "exec": "curl -s 'https://wttr.in/Sao_Paulo?format=2' | sed 's/  */ /g' | jq --unbuffered --compact-output -M -R '{text:.}'",
    "exec-if": "ping wttr.in -c1"
  }
}
