{
  "font": "JetBrainsMono Nerd Font",
  "reload_style_on_change": true,
  "width": 1920,
  "spacing": 1,
  "modules-left": ["group/quick-actions", "wlr/taskbar", "tray", "privacy"],
  "modules-center": ["hyprland/workspaces", "sway/workspaces"],
  "modules-right": [
    "custom/weather",
    "network",
    "pulseaudio",
    "group/hardware",
    "clock",
    "custom/notification"
  ],

  "sway/workspaces": {
    "format": "{icon}",
    "format-icons": {
      "1": "¾░¢¤ ",
      "2": "Ņ×Ģ ",
      "3": "’ü╝ ",
      "4": "’Ćü ",
      "5": "Ņ¼” ",
      "6": "’ćü ",
      "urgent": "’ü¬"
    },
    "persistent-workspaces": {
      "1": [],
      "2": [],
      "3": [],
      "4": [],
      "5": [],
      "6": []
    }
  },

  "hyprland/workspaces": {
    "format": "{icon}",
    "format-icons": {
      "1": "¾░¢¤",
      "2": "Ņ×Ģ",
      "3": "’ü╝",
      "4": "’Ćü",
      "5": "Ņ¼”",
      "6": "’ćü",

      "urgent": "’ü¬"
    },
    "persistent-workspaces": {
      "1": [],
      "2": [],
      "3": [],
      "4": [],
      "5": [],
      "6": []
    }
  },

  "tray": {
    "icon-size": 15,
    "spacing": 15,
    "show-passive-items": false
  },

  "group/quick-actions": {
    "orientation": "horizontal",
    "modules": [
      "custom/power-menu",
      "idle_inhibitor",
      "bluetooth",
      "power-profiles-daemon",
      "custom/themes"
    ]
  },
  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": "’ü« ",
      "deactivated": "’ü░ "
    }
  },
  "custom/power-menu": {
    "format": "’Ćæ ",
    "tooltip": true,
    "tooltip-format": "’Ćæ Open Wlogout!",
    "on-click": "~/.config/hypr/scripts/power-menu.sh"
  },

  "group/settings": {
    "orientation": "horizontal",
    "modules": []
  },
  "temperature": {
    "critical-threshold": 80,
    "format": "{temperatureC}┬░C {icon}",
    "format-icons": ["’Ø½", "’ŗē", "’Ø®"]
  },

  "pulseaudio": {
    "format": "{volume}% {icon}",
    "format-bluetooth": "{volume}% {icon}’Ŗö {format_source}",
    "format-bluetooth-muted": "’Ü® {icon}’Ŗö {format_source}",
    "format-muted": "Ņ¼ż ¾░Ø¤ ’æ” {format_source}",
    "format-source": "{volume}% ’ä░",
    "format-source-muted": "’ä▒",
    "format-icons": {
      "default": ["’Ć”", "’Ć¦ ", "’Ć© "]
    },
    "max-volume": 150,
    "on-click": "pavucontrol"
  },

  "power-profiles-daemon": {
    "format": "{icon}",
    "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
    "tooltip": true,
    "format-icons": {
      "default": "¾▒Éŗ",
      "performance": "¾▒Éŗ",
      "balanced": "¾░Śæ",
      "power-saver": "Ņł£"
    }
  },

  "custom/themes": {
    "exec": "sleep 0.2; $HOME/.config/hypr/functions.sh get_theme",
    "tooltip": true,
    "return-type": "json",
    "format": "{icon}",
    "format-icons": {
      "dark": "’ō« ",
      "light": "’öó "
    },
    "on-click": "$HOME/.config/hypr/functions.sh change_theme",
    "signal": 12,
    "interval": 5
  },

  "privacy": {
    "icon-spacing": 4,
    "icon-size": 15,
    "transition-duration": 250,
    "modules": [
      {
        "type": "screenshare",
        "tooltip": true,
        "tooltip-icon-size": 18
      },
      {
        "type": "audio-out",
        "tooltip": true,
        "tooltip-icon-size": 18
      },
      {
        "type": "audio-in",
        "tooltip": true,
        "tooltip-icon-size": 18
      }
    ]
  },
  "backlight": {
    "tooltip": false,
    "format": "’ā½ {}%",
    "interval": 10,
    "on-scroll-up": "brightnessctl set 5%+",
    "on-scroll-down": "brightnessctl set 5%-"
  },

  "bluetooth": {
    "format-off": "¾░é▓",
    "format-on": "’Ŗö",
    "format-disabled": "¾░é▓",
    "format-connected": "’Ŗö {device_alias}",
    "format-connected-battery": "’Ŗö {device_alias} {device_battery_percentage}%",
    "tooltip-format": "{controller_alias}\t{controller_address}\n\n{num_connections} connected",
    "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{num_connections} connected\n\n{device_enumerate}",
    "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
    "tooltip-format-enumerate-connected-battery": "{device_alias}\t{device_address}\t{device_battery_percentage}%",
    "on-click": "blueman-manager"
  },

  // Network setup
  "network": {
    "format": "{ifname}",
    "format-wifi": "{essid} ¾░ż© ",
    "format-disconnected": " ¾░żŁ ",
    "tooltip-format-wifi": "{essid} ¾░ż© ",
    "tooltip-format-disconnected": "Disconnected",
    "max-length": 50,
    "interval": 2,
    "exec-if": "which nm-connection-editor",
    "exec": "nm-connection-editor",
    "on-click": "nm-connection-editor"
  },

  "custom/notification": {
    "tooltip": false,
    "format-icons": {
      "notification": "’éó<span foreground='red'><sup>’æä</sup></span>",
      "none": "’éó",
      "dnd-notification": "’ćĘ<span foreground='red'><sup>’æä</sup></span>",
      "dnd-none": "’ćĘ",
      "inhibited-notification": "’éó<span foreground='red'><sup>’æä</sup></span>",
      "inhibited-none": "’éó",
      "dnd-inhibited-notification": "’ćĘ<span foreground='red'><sup>’æä</sup></span>",
      "dnd-inhibited-none": "’ćĘ"
    },
    "format": "{icon} ",
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
  },

  "group/hardware": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 500,
      "transition-left-to-right": false
    },
    "modules": ["battery", "cpu", "memory"]
  },

  "custom/weather": {
    "exec": "python /home/neimog/Documents/Git/dotfiles/Config/waybar/Scripts/weather.py",
    "restart-interval": 300,
    "return-type": "json"
  },

  "battery": {
    "on-click": "flatpak run net.nokyan.Resources",
    "states": {
      "good": 70,
      "warning": 30,
      "critical": 15
    },
    "format": "{capacity}% {icon}",
    "format-charging": "’ć”  {capacity}%",
    "format-icons": ["¾░éÄ", "¾░ü║", "¾░ü╗", "¾░ü╝", "¾░üĮ", "¾░üŠ", "¾░ü┐", "¾░éĆ", "¾░éü", "¾░éé", "¾░ü╣"],
    "signal": 12,
    "interval": 5
  },

  "cpu": {
    "format": " {usage}% ’ŗø ",
    "tooltip": false
  },

  "memory": {
    "format": " {}% Ņē” "
  },
  "clock": {
    "format": "¾▒æé {:%R %a %d %b}",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
    "format-alt": "¾░©│ {:%d %b}"
  }
}
