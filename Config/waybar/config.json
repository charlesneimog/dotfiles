{
  "font": "JetBrainsMono Nerd Font",
  "reload_style_on_change": true,
  "width": 1920,
  "spacing": 1,
  "modules-left": ["group/quicklinks-right", "wlr/taskbar", "tray"],
  "modules-center": ["hyprland/workspaces"],
  "modules-right": [
    "custom/weather",
    "network",
    "pulseaudio",
    "group/hardware",
    "clock",
    "custom/notification"
  ],

  "wlr/taskbar": {
    "format": "{icon}",
    "icon-size": "15",
    "on-click": "activate",
    "on-click-right": "close",
    "tooltip-format": "Go to {title}",
    "ignore-list": ["kitty", "kitty-scratchpad"]
  },

  "hyprland/workspaces": {
    "format": "{icon}",
    "format-icons": {
      "1": "¾░¢¤",
      "2": "Ņ×Ģ",
      "3": "’ü╝",
      "4": "’Ćü",
      "5": "Ņ¼”",
      "6": "’ćü",

      "urgent": "’ü¬"
    },
    "persistent-workspaces": {
      "1": [],
      "2": [],
      "3": [],
      "4": [],
      "5": [],
      "6": []
    }
  },

  "tray": {
    "icon-size": 18,
    "spacing": 15,
    "show-passive-items": true
  },

  "hyprland/window": {
    "format": "",
    "icon": true,
    "icon-size": 18,
    "max-length": 30,
    "separate-outputs": true,
    "rewrite": {
      "(.*) - Brave": "$1"
    }
  },

  // Quicklinks
  "group/quicklinks-left": {
    "orientation": "horizontal",
    "modules": ["image", "custom/terminal", "custom/browser", "custom/explorer"]
  },

  "group/quicklinks-right": {
    "orientation": "horizontal",
    "modules": ["custom/power-menu", "idle_inhibitor", "power-profiles-daemon"]
  },
  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": "’ü« ",
      "deactivated": "’ü░ "
    }
  },
  "custom/power-menu": {
    "format": "’Ćæ ",
    "tooltip": true,
    "tooltip-format": "’Ćæ Open Wlogout!",
    "on-click": "~/.config/hypr/scripts/power-menu.sh"
  },

  "group/settings": {
    "orientation": "horizontal",
    "modules": []
  },
  "temperature": {
    "critical-threshold": 80,
    "format": "{temperatureC}┬░C {icon}",
    "format-icons": ["’Ø½", "’ŗē", "’Ø®"]
  },

  "pulseaudio": {
    "format": "{volume}% {icon}",
    "format-bluetooth": "{volume}% {icon}’Ŗö {format_source}",
    "format-bluetooth-muted": "’Ü® {icon}’Ŗö {format_source}",
    "format-muted": "Ņ¼ż ¾░Ø¤ ’æ” {format_source}",
    "format-source": "{volume}% ’ä░",
    "format-source-muted": "’ä▒",
    "format-icons": {
      "default": ["’Ć”", "’Ć¦ ", "’Ć© "]
    },
    "max-volume": 150,
    "on-click": "pavucontrol"
  },

  "power-profiles-daemon": {
    "format": "{icon}",
    "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
    "tooltip": true,
    "format-icons": {
      "default": "¾▒Éŗ",
      "performance": "¾▒Éŗ",
      "balanced": "¾░Śæ",
      "power-saver": "Ņł£"
    }
  },

  // Network setup
  "network": {
    "format": "{ifname}",
    "format-wifi": "{essid} ’ć½ ",
    "format-ethernet": "{bandwidthDownBytes} ŅĮä ",
    "format-disconnected": "",
    "tooltip-format": "{ifname} via {gwaddr} ¾░ŖŚ",
    "tooltip-format-wifi": "{essid} ’ć½",
    "tooltip-format-ethernet": "{ifname} ŅĮä ",
    "tooltip-format-disconnected": "Disconnected",
    "max-length": 50,
    "interval": 2
  },

  "custom/notification": {
    "tooltip": false,
    "format-icons": {
      "notification": "’éó<span foreground='red'><sup>’æä</sup></span>",
      "none": "’éó",
      "dnd-notification": "’ćĘ<span foreground='red'><sup>’æä</sup></span>",
      "dnd-none": "’ćĘ",
      "inhibited-notification": "’éó<span foreground='red'><sup>’æä</sup></span>",
      "inhibited-none": "’éó",
      "dnd-inhibited-notification": "’ćĘ<span foreground='red'><sup>’æä</sup></span>",
      "dnd-inhibited-none": "’ćĘ"
    },
    "format": "{icon} ",
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
  },

  "battery": {
    "states": {
      "good": 95,
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-charging": "’ć”  {capacity}%",
    "format-icons": ["¾░éÄ", "¾░ü║", "¾░ü╗", "¾░ü╝", "¾░üĮ", "¾░üŠ", "¾░ü┐", "¾░éĆ", "¾░éü", "¾░éé", "¾░ü╣"],
    "signal": 12,
    "interval": 5
  },

  "group/hardware": {
    "orientation": "horizontal",
    "modules": ["battery", "cpu", "memory"]
  },
  "cpu": {
    "format": " {usage}% ’ŗø ",
    "tooltip": false
  },
  "memory": {
    "format": " {}% Ņē” "
  },
  "clock": {
    "format": "¾▒æé {:%R %a}",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
    "format-alt": "¾░©│ {:%d %b %Y}"
  },
  "custom/weather": {
    "format": "{}",
    "interval": 300,
    "return-type": "json",
    "exec": "curl -s 'https://wttr.in/Sao_Paulo?format=1' |jq --unbuffered --compact-output -M -R '{text:.}'",
    "exec-if": "ping wttr.in -c1"
  }
}
